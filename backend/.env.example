# Backend configuration. Copy to .env and fill in real values for local runs.
# Never commit real secrets.

APP_ENV=development
HTTP_PORT=8080

# PostgreSQL connection string (pgx stdlib driver).
DATABASE_URL=postgres://cipherkeep:cipherkeep@localhost:5432/cipherkeep?sslmode=disable

# REQUIRED. Master password used to derive the KEK (envelope encryption).
# Losing this makes all stored secrets unrecoverable. Back it up securely.
# Must be >= 16 chars, not a placeholder. Generate: openssl rand -hex 24
MASTER_PASSWORD=replace-with-openssl-rand-hex-24

# REQUIRED. Secret used to sign JWT access tokens.
# Must be >= 32 chars, not a placeholder. Generate: openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# Token lifetimes (Go duration syntax).
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Comma-separated reverse-proxy CIDRs whose X-Forwarded-For is trusted. Empty
# (default) trusts none, preventing IP spoofing of the rate limiter.
TRUSTED_PROXIES=

# Maximum request body size in bytes (default 1 MiB).
MAX_BODY_BYTES=1048576

# Log level: trace|debug|info|warn|error.
LOG_LEVEL=info
