# Root environment for docker-compose. Copy to .env and fill in real values.
#   cp .env.example .env
# Never commit the real .env.

# --- PostgreSQL ---
POSTGRES_USER=cipherkeep
POSTGRES_PASSWORD=cipherkeep
POSTGRES_DB=cipherkeep
# Host port to expose Postgres on (dev override only).
POSTGRES_PORT=5432

# --- API (REQUIRED secrets) ---
# Master password used to derive the KEK for envelope encryption.
# Losing this makes ALL stored secrets permanently unrecoverable. Back it up securely.
# Must be >= 16 chars and not a placeholder. Generate with: openssl rand -hex 24
MASTER_PASSWORD=replace-with-output-of-openssl-rand-hex-24

# Secret used to sign JWT access tokens.
# Must be >= 32 chars and not a placeholder. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Comma-separated reverse-proxy CIDRs whose X-Forwarded-For is trusted (for correct
# client IPs behind a proxy). EMPTY (default) trusts none, so clients cannot spoof
# their IP to evade rate limiting. Example behind Docker: 172.16.0.0/12
TRUSTED_PROXIES=

# Maximum request body size in bytes (default 1048576 = 1 MiB).
MAX_BODY_BYTES=1048576

# Token lifetimes (Go duration syntax).
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Log level: trace|debug|info|warn|error.
LOG_LEVEL=info

# Host port the API is published on.
API_PORT=8080

# --- Frontend ---
# Host port the SPA is served on. Must match the origin in CORS_ALLOWED_ORIGINS below.
FRONTEND_PORT=5173

# API base URL baked into the SPA at build time. Must be reachable from the browser.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Origins allowed by the API's CORS policy (comma-separated). Match the frontend origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173
